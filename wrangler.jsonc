{
  // zelda.horse — static page, served as an assets-only Worker (free plan friendly).
  // No server code: everything in ./public is served directly.
  "name": "zelda-horse",
  "compatibility_date": "2026-06-01",
  "assets": { "directory": "./public" }

  // After your zone is on Cloudflare, add zelda.horse as a Custom Domain in the
  // dashboard (Workers > zelda-horse > Settings), or uncomment:
  // "routes": [{ "pattern": "zelda.horse", "custom_domain": true }]
}
